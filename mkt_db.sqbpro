FROM mkt_data
LIMIT 5;


CREATE VIEW aggre_level AS 
SELECT 
    category,
    COUNT(merchant_id) AS count_merchant,
    CAST(SUM(impressions) AS FLOAT) AS total_impression,
    CAST(SUM(clicks) AS FLOAT) AS total_click,
    CAST(SUM(cost_thb) AS FLOAT) AS total_cost,
    CAST(SUM(gmv_from_ads_thb) AS FLOAT) AS total_gmv
FROM mkt_data
GROUP BY category;

CREATE VIEW key_kpi AS
SELECT *,
	ROUND((total_click/total_impression)*100,2) AS CTR,
	ROUND((total_click/total_cost)*100,2) AS CPC,
--- Return on Advertising Spend ROADS -- 
	ROUND((total_gmv/total_cost)*100,2) AS ROAS 
 FROM aggre_level;

SELECT * 
FROM key_kpi;</sql><current_tab id="0"/></tab_sql></sqlb_project>
